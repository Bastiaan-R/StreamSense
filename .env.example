# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Jellyfin Configuration
JELLYFIN_URL="http://your-jellyfin-url:8096"
JELLYFIN_API_KEY="your_jellyfin_api_key"

# Seerr Configuration (Overseerr or Jellyseerr)
SEERR_URL="http://your-seerr-url:5055"
SEERR_API_KEY="your_seerr_api_key"

# TMDB Configuration
TMDB_READ_ACCESS_TOKEN="your_tmdb_read_access_token"

# Sync Configuration
HISTORY_SYNC_INTERVAL_HOURS="12"
RECS_SYNC_INTERVAL_HOURS="24"

# Admin Configuration
# Comma-separated list of Jellyfin User IDs who should have admin access
ADMIN_USER_IDS="your_jellyfin_user_id_1,your_jellyfin_user_id_2"

# Security Configuration
# JWT_SECRET: Used to sign session tokens securely. Give it a random string.
JWT_SECRET="generate_a_random_string_here_for_jwt"
# ENCRYPTION_KEY: Used to encrypt Jellyfin tokens in the database. Give it a secure 32 byte random hex string.
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Security Configuration
# JWT_SECRET: Used to sign session tokens securely. Give it a random string.
JWT_SECRET="generate_a_random_string_here_for_jwt"
# ENCRYPTION_KEY: Used to encrypt Jellyfin tokens in the database. Give it a secure 32 byte random hex string.
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
